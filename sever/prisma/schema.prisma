generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int      @id @default(autoincrement())
  name              String   @db.VarChar(191)
  email             String   @unique @db.VarChar(191)
  password_hash     String?
  provider          String   @default("credentials")
  oauth_id          String?
  image             String?
  is_email_verified Boolean  @default(false)

  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  deleted_at        DateTime?

  customers         Customer[]
  suppliers         Supplier[]
  categories        Category[]
  products          Product[]
  warehouses        Warehouse[]
  purchases         Purchase[]
  sales             Sale[]
  invoices          Invoice[]
  payments          Payment[]
  resets            PasswordResetToken[]

  @@map("users")
}

model Customer {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id    Int

  name       String   @db.VarChar(191)
  email      String?
  phone      String?
  address    String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  invoices   Invoice[]
  sales      Sale[]

  @@index([user_id])
  @@map("customers")
}

model Supplier {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id    Int

  name       String
  email      String?
  phone      String?
  address    String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  purchases  Purchase[]

  @@index([user_id])
  @@map("suppliers")
}

model Category {
  id         Int      @id @default(autoincrement())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id    Int

  name       String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  products   Product[]

  @@unique([user_id, name])
  @@index([user_id])
  @@map("categories")
}

model Product {
  id            Int       @id @default(autoincrement())

  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id       Int

  category      Category? @relation(fields: [category_id], references: [id], onDelete: SetNull)
  category_id   Int?

  name          String
  sku           String
  barcode       String?   @unique

  price         Decimal   @db.Decimal(12,2)
  cost          Decimal?  @db.Decimal(12,2)

  gst_rate      Decimal   @default(18) @db.Decimal(5,2)

  stock_on_hand Int       @default(0)
  reorder_level Int       @default(0)

  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]
  invoiceItems  InvoiceItem[]
  movements     StockMovement[]
  inventories   Inventory[]

  @@unique([user_id, sku])
  @@index([user_id])
  @@index([category_id])
  @@map("products")
}

model Warehouse {
  id        Int      @id @default(autoincrement())

  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id   Int

  name      String
  location  String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  inventories Inventory[]
  purchases   Purchase[]

  @@index([user_id])
  @@map("warehouses")
}

model Inventory {
  id           Int @id @default(autoincrement())

  warehouse    Warehouse @relation(fields: [warehouse_id], references: [id], onDelete: Cascade)
  warehouse_id Int

  product      Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_id   Int

  quantity     Int @default(0)

  @@unique([warehouse_id, product_id])
  @@map("inventories")
}

model Purchase {
  id            Int       @id @default(autoincrement())

  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id       Int

  supplier      Supplier? @relation(fields: [supplier_id], references: [id], onDelete: SetNull)
  supplier_id   Int?

  warehouse     Warehouse? @relation(fields: [warehouse_id], references: [id], onDelete: SetNull)
  warehouse_id  Int?

  purchase_date DateTime  @default(now())

  subtotal      Decimal   @db.Decimal(12,2)
  tax           Decimal   @db.Decimal(12,2)
  total         Decimal   @db.Decimal(12,2)

  notes         String?

  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  items         PurchaseItem[]

  @@index([user_id])
  @@index([supplier_id])
  @@index([warehouse_id])
  @@map("purchases")
}

model PurchaseItem {
  id          Int      @id @default(autoincrement())

  purchase    Purchase @relation(fields: [purchase_id], references: [id], onDelete: Cascade)
  purchase_id Int

  product     Product? @relation(fields: [product_id], references: [id])
  product_id  Int?

  name        String
  quantity    Int
  unit_cost   Decimal  @db.Decimal(12,2)
  tax_rate    Decimal? @db.Decimal(5,2)
  line_total  Decimal  @db.Decimal(12,2)

  @@index([purchase_id])
  @@map("purchase_items")
}

model Sale {
  id          Int        @id @default(autoincrement())

  user        User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id     Int

  customer    Customer?  @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  customer_id Int?

  status      SaleStatus @default(COMPLETED)

  sale_date   DateTime   @default(now())

  subtotal    Decimal    @db.Decimal(12,2)
  tax         Decimal    @db.Decimal(12,2)
  total       Decimal    @db.Decimal(12,2)

  notes       String?

  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  items       SaleItem[]

  @@index([user_id])
  @@index([customer_id])
  @@map("sales")
}

model SaleItem {
  id         Int      @id @default(autoincrement())

  sale       Sale     @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  sale_id    Int

  product    Product? @relation(fields: [product_id], references: [id])
  product_id Int?

  name       String
  quantity   Int

  unit_price Decimal  @db.Decimal(12,2)
  tax_rate   Decimal? @db.Decimal(5,2)

  line_total Decimal  @db.Decimal(12,2)

  @@index([sale_id])
  @@map("sale_items")
}

model Invoice {
  id          Int           @id @default(autoincrement())

  user        User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id     Int

  customer    Customer      @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  customer_id Int

  status      InvoiceStatus @default(DRAFT)

  issue_date  DateTime      @default(now())
  due_date    DateTime?

  subtotal    Decimal       @db.Decimal(12,2)
  tax         Decimal       @db.Decimal(12,2)
  total       Decimal       @db.Decimal(12,2)

  notes       String?

  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt

  items       InvoiceItem[]
  payments    Payment[]

  @@index([user_id])
  @@index([customer_id])
  @@map("invoices")
}

model InvoiceItem {
  id         Int      @id @default(autoincrement())

  invoice    Invoice  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  invoice_id Int

  product    Product? @relation(fields: [product_id], references: [id])
  product_id Int?

  name       String
  quantity   Int

  unit_price Decimal  @db.Decimal(12,2)
  tax_rate   Decimal? @db.Decimal(5,2)

  line_total Decimal  @db.Decimal(12,2)

  @@index([invoice_id])
  @@map("invoice_items")
}

model Payment {
  id         Int           @id @default(autoincrement())

  user       User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id    Int

  invoice    Invoice       @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  invoice_id Int

  amount     Decimal       @db.Decimal(12,2)
  method     PaymentMethod

  reference  String?

  paid_at    DateTime      @default(now())
  created_at DateTime      @default(now())

  @@index([invoice_id])
  @@index([user_id])
  @@map("payments")
}

model StockMovement {
  id         Int         @id @default(autoincrement())

  product    Product     @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_id Int

  change     Int
  reason     StockReason

  note       String?

  created_at DateTime    @default(now())

  @@index([product_id])
  @@map("stock_movements")
}

model PasswordResetToken {
  id         Int      @id @default(autoincrement())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id    Int

  token      String   @unique
  expires_at DateTime
  used_at    DateTime?

  created_at DateTime @default(now())

  @@index([user_id])
  @@map("password_reset_tokens")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  UPI
  CHEQUE
  OTHER
}

enum StockReason {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
  DAMAGE
}

enum SaleStatus {
  DRAFT
  COMPLETED
  VOID
}